---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Blog">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-dark to-dark"></div>
    <div class="relative mx-auto max-w-6xl px-6 py-24">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-light">Thoughts & Updates</p>
      <h1 class="mt-2 text-4xl font-black sm:text-5xl">The <span class="gradient-text">Blog</span></h1>
      <p class="mt-4 text-lg text-light/50">Music, life, and everything in between.</p>
    </div>
  </section>

  <!-- Blog Posts -->
  <section class="border-t border-dark-border">
    <div class="mx-auto max-w-4xl px-6 py-16">
      <div class="space-y-8">
        <!-- Blog Post 1 -->
        <article class="group rounded-xl border border-dark-border bg-dark-card p-8 hover:border-primary/30 transition-all cursor-pointer">
          <div class="flex items-center gap-3 text-xs text-light/40">
            <time>March 1, 2026</time>
            <span>·</span>
            <span>5 min read</span>
            <span class="rounded-full bg-primary/10 px-3 py-0.5 text-primary-light">Music</span>
          </div>
          <h2 class="mt-4 text-2xl font-bold group-hover:text-primary-light transition-colors">
            Why Seattle's Music Scene is About to Explode
          </h2>
          <p class="mt-3 text-light/50 leading-relaxed">
            From underground venues to rooftop sessions, Seattle has always had a special relationship with music. 
            But something different is brewing in 2026, and I'm here for it...
          </p>
          <span class="mt-4 inline-block text-sm font-medium text-primary-light">Read more →</span>
        </article>

        <!-- Blog Post 2 -->
        <article class="group rounded-xl border border-dark-border bg-dark-card p-8 hover:border-primary/30 transition-all cursor-pointer">
          <div class="flex items-center gap-3 text-xs text-light/40">
            <time>February 15, 2026</time>
            <span>·</span>
            <span>3 min read</span>
            <span class="rounded-full bg-accent/10 px-3 py-0.5 text-accent">Behind the Scenes</span>
          </div>
          <h2 class="mt-4 text-2xl font-bold group-hover:text-primary-light transition-colors">
            A Day in the Life: Radio to the Club
          </h2>
          <p class="mt-3 text-light/50 leading-relaxed">
            People always ask what it's like to do radio during the week and DJ on weekends. 
            Here's what a typical Friday looks like when you live a double life...
          </p>
          <span class="mt-4 inline-block text-sm font-medium text-primary-light">Read more →</span>
        </article>

        <!-- Blog Post 3 -->
        <article class="group rounded-xl border border-dark-border bg-dark-card p-8 hover:border-primary/30 transition-all cursor-pointer">
          <div class="flex items-center gap-3 text-xs text-light/40">
            <time>January 28, 2026</time>
            <span>·</span>
            <span>4 min read</span>
            <span class="rounded-full bg-primary/10 px-3 py-0.5 text-primary-light">Gear</span>
          </div>
          <h2 class="mt-4 text-2xl font-bold group-hover:text-primary-light transition-colors">
            My 2026 Setup: Gear That Makes the Magic Happen
          </h2>
          <p class="mt-3 text-light/50 leading-relaxed">
            Every DJ gets asked about their setup. Here's what I'm rocking this year, 
            from controllers to headphones, and why each piece matters...
          </p>
          <span class="mt-4 inline-block text-sm font-medium text-primary-light">Read more →</span>
        </article>
      </div>
    </div>
  </section>
</Layout>
