---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categoryColors: Record<string, string> = {
  'Music': 'bg-primary/10 text-primary-light',
  'Behind the Scenes': 'bg-accent/10 text-accent',
  'Gear': 'bg-primary/10 text-primary-light',
  'Life': 'bg-green-500/10 text-green-400',
  'Events': 'bg-accent/10 text-accent',
};
---

<Layout title="Blog">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-dark to-dark"></div>
    <div class="relative mx-auto max-w-6xl px-6 py-24">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-light">Thoughts & Updates</p>
      <h1 class="mt-2 text-4xl font-black sm:text-5xl">The <span class="gradient-text">Blog</span></h1>
      <p class="mt-4 text-lg text-light/50">Music, life, and everything in between.</p>
    </div>
  </section>

  <!-- Blog Posts -->
  <section class="border-t border-dark-border">
    <div class="mx-auto max-w-4xl px-6 py-16">
      <div class="space-y-8">
        {posts.map((post) => (
          <article class="group rounded-xl border border-dark-border bg-dark-card p-8 hover:border-primary/30 transition-all cursor-pointer">
            <div class="flex items-center gap-3 text-xs text-light/40">
              <time>{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              <span>·</span>
              <span>{post.data.readTime}</span>
              <span class={`rounded-full px-3 py-0.5 ${categoryColors[post.data.category] || 'bg-primary/10 text-primary-light'}`}>{post.data.category}</span>
            </div>
            <h2 class="mt-4 text-2xl font-bold group-hover:text-primary-light transition-colors">
              {post.data.title}
            </h2>
            <p class="mt-3 text-light/50 leading-relaxed">
              {post.body?.slice(0, 200)}...
            </p>
            <span class="mt-4 inline-block text-sm font-medium text-primary-light">Read more →</span>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
