---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL;

const allMedia = (await getCollection('media')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const videos = allMedia.filter((m) => m.data.type === 'Video');
const mixes = allMedia.filter((m) => m.data.type === 'Mix');
const photos = allMedia.filter((m) => m.data.type === 'Photo');
---

<Layout title="Media">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-dark to-dark"></div>
    <div class="relative mx-auto max-w-6xl px-6 py-24">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-light">Gallery</p>
      <h1 class="mt-2 text-4xl font-black sm:text-5xl">Photos & <span class="gradient-text">Videos</span></h1>
      <p class="mt-4 text-lg text-light/50">Highlights from the decks, the stage, and behind the scenes.</p>
    </div>
  </section>

  <!-- Videos Section -->
  {videos.length > 0 && (
    <section class="border-t border-dark-border">
      <div class="mx-auto max-w-6xl px-6 py-16">
        <h2 class="text-2xl font-bold mb-8">Videos</h2>
        <div class="grid gap-6 md:grid-cols-2">
          {videos.map((video) => (
            <div class="rounded-xl border border-dark-border bg-dark-card overflow-hidden hover:border-primary/30 transition-all">
              {video.data.url ? (
                <div class="aspect-video">
                  <iframe
                    src={video.data.url.replace('watch?v=', 'embed/')}
                    class="w-full h-full"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  />
                </div>
              ) : video.data.thumbnail ? (
                <div class="aspect-video">
                  <img src={`${base}${video.data.thumbnail.replace(/^\//, '')}`} alt={video.data.title} class="w-full h-full object-cover" />
                </div>
              ) : (
                <div class="aspect-video flex items-center justify-center">
                  <div class="text-center text-light/30">
                    <div class="text-4xl mb-2">🎬</div>
                    <p class="text-sm">Video coming soon</p>
                  </div>
                </div>
              )}
              <div class="p-4">
                <h3 class="font-bold text-lg">{video.data.title}</h3>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Mixes Section -->
  {mixes.length > 0 && (
    <section class="border-t border-dark-border">
      <div class="mx-auto max-w-6xl px-6 py-16">
        <h2 class="text-2xl font-bold mb-8">Mixes</h2>
        <div class="space-y-4">
          {mixes.map((mix) => (
            <div class="rounded-xl border border-dark-border bg-dark-card p-6 hover:border-primary/30 transition-all">
              <div class="flex items-center gap-4">
                {mix.data.thumbnail && (
                  <img src={`${base}${mix.data.thumbnail.replace(/^\//, '')}`} alt={mix.data.title} class="w-16 h-16 rounded-lg object-cover" />
                )}
                <div class="flex-grow">
                  <h3 class="font-bold text-lg">{mix.data.title}</h3>
                  <p class="text-sm text-light/40">{new Date(mix.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                </div>
                {mix.data.url && (
                  <a href={mix.data.url} target="_blank" rel="noopener" class="rounded-full bg-primary px-5 py-2 text-sm font-semibold text-white hover:bg-primary-light transition-colors">
                    Listen
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Photo Gallery -->
  {photos.length > 0 && (
    <section class="border-t border-dark-border bg-dark-card">
      <div class="mx-auto max-w-6xl px-6 py-16">
        <h2 class="text-2xl font-bold mb-8">Photos</h2>
        <div class="grid gap-4 grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
          {photos.map((photo) => (
            <div class="aspect-square rounded-xl overflow-hidden border border-dark-border hover:border-primary/30 transition-all cursor-pointer group">
              <img src={`${base}${photo.data.thumbnail.replace(/^\//, '')}`} alt={photo.data.title} class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-300" />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Empty state if no media at all -->
  {allMedia.length === 0 && (
    <section class="border-t border-dark-border">
      <div class="mx-auto max-w-4xl px-6 py-24 text-center">
        <p class="text-4xl mb-4">🎵</p>
        <p class="text-light/50">Media coming soon — check back!</p>
      </div>
    </section>
  )}
</Layout>
