---
import Layout from '../layouts/Layout.astro';

const photos = [
  { src: '/images/crowd-blue.jpg', alt: 'DJ Phase performing - crowd with blue lights' },
  { src: '/images/crowd-lucky-strike.jpg', alt: 'DJ Phase at Lucky Strike Lanes' },
  { src: '/images/djphase-decks.jpg', alt: 'DJ Phase behind the decks' },
  { src: '/images/headshot-1.jpg', alt: 'DJ Phase portrait' },
  { src: '/images/headshot-2.jpg', alt: 'DJ Phase' },
  { src: '/images/headshot-3.jpg', alt: 'DJ Phase - dramatic lighting' },
  { src: '/images/headshot-4.jpg', alt: 'DJ Phase - close up' },
];
---

<Layout title="Media">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-dark to-dark"></div>
    <div class="relative mx-auto max-w-6xl px-6 py-24">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-light">Gallery</p>
      <h1 class="mt-2 text-4xl font-black sm:text-5xl">Photos & <span class="gradient-text">Videos</span></h1>
      <p class="mt-4 text-lg text-light/50">Highlights from the decks, the stage, and behind the scenes.</p>
    </div>
  </section>

  <!-- Video Section -->
  <section class="border-t border-dark-border">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <h2 class="text-2xl font-bold mb-8">Videos</h2>
      <div class="grid gap-6 md:grid-cols-2">
        <!-- Video placeholder 1 -->
        <div class="aspect-video rounded-xl border border-dark-border bg-dark-card flex items-center justify-center">
          <div class="text-center text-light/30">
            <div class="text-4xl mb-2">🎬</div>
            <p class="text-sm">Video coming soon</p>
          </div>
        </div>
        <!-- Video placeholder 2 -->
        <div class="aspect-video rounded-xl border border-dark-border bg-dark-card flex items-center justify-center">
          <div class="text-center text-light/30">
            <div class="text-4xl mb-2">🎬</div>
            <p class="text-sm">Video coming soon</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Gallery -->
  <section class="border-t border-dark-border bg-dark-card">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <h2 class="text-2xl font-bold mb-8">Photos</h2>
      <div class="grid gap-4 grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {photos.map((photo) => (
          <div class="aspect-square rounded-xl overflow-hidden border border-dark-border hover:border-primary/30 transition-all cursor-pointer group">
            <img src={photo.src} alt={photo.alt} class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-300" />
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
