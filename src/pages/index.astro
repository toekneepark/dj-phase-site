---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="relative flex min-h-[90vh] items-center justify-center overflow-hidden">
    <!-- Background image -->
    <div class="absolute inset-0">
      <img src={`${base}images/crowd-blue.jpg`} alt="DJ Phase performing" class="h-full w-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-dark/60 via-dark/70 to-dark"></div>
    </div>
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 h-[500px] w-[500px] rounded-full bg-primary/20 blur-[120px]"></div>

    <div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.3em] text-primary-light">iHeartRadio • Seattle • Legendary</p>
      <h1 class="text-6xl font-black leading-tight tracking-tight sm:text-7xl md:text-8xl">
        <span class="gradient-text">DJ PHASE</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-light/60 sm:text-xl">
        Radio personality. Club residencies. Stadium events. Remix creator. Seattle's most versatile DJ — bringing the energy everywhere from Seahawks games to your favorite nightclub.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={`${base}contact`} class="inline-flex items-center rounded-full bg-primary px-8 py-3 text-sm font-semibold text-white hover:bg-primary-light transition-all glow-purple">
          Book DJ Phase
        </a>
        <a href={`${base}gigs`} class="inline-flex items-center rounded-full border border-light/20 px-8 py-3 text-sm font-semibold text-light hover:border-light/40 transition-all">
          See Where I'm Playing →
        </a>
      </div>
    </div>
  </section>

  <!-- What I Do Section -->
  <section class="border-t border-dark-border bg-dark-card">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <div class="grid gap-12 md:grid-cols-4">
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-primary/10">
            <span class="text-2xl">🎙️</span>
          </div>
          <h3 class="text-lg font-bold">iHeartRadio</h3>
          <p class="mt-2 text-sm text-light/50">On-air personality bringing the best music to the Pacific Northwest.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-primary/10">
            <span class="text-2xl">🏈</span>
          </div>
          <h3 class="text-lg font-bold">Seahawks DJ</h3>
          <p class="mt-2 text-sm text-light/50">Rocking the 300 Level concourse at Lumen Field on game days.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-primary/10">
            <span class="text-2xl">🎧</span>
          </div>
          <h3 class="text-lg font-bold">Club Residencies</h3>
          <p class="mt-2 text-sm text-light/50">Every Friday at Fuego. Weekends at Legion. Always bringing the heat.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-primary/10">
            <span class="text-2xl">🔥</span>
          </div>
          <h3 class="text-lg font-bold">Bar Bangerz</h3>
          <p class="mt-2 text-sm text-light/50">Custom DJ edits, remixes & mashups. The secret weapon in every set.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Photo Section -->
  <section class="border-t border-dark-border">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <div class="grid gap-6 md:grid-cols-3">
        <div class="group relative overflow-hidden rounded-2xl aspect-square">
          <img src={`${base}images/crowd-lucky-strike.jpg`} alt="DJ Phase at Lucky Strike" class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-dark/80 via-transparent to-transparent"></div>
          <div class="absolute bottom-4 left-4">
            <p class="text-xs font-semibold uppercase tracking-wider text-primary-light">Live</p>
            <p class="text-lg font-bold">Lucky Strike Lanes</p>
          </div>
        </div>
        <div class="group relative overflow-hidden rounded-2xl aspect-square">
          <img src={`${base}images/djphase-decks.jpg`} alt="DJ Phase behind the decks" class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-dark/80 via-transparent to-transparent"></div>
          <div class="absolute bottom-4 left-4">
            <p class="text-xs font-semibold uppercase tracking-wider text-primary-light">Behind the Decks</p>
            <p class="text-lg font-bold">Icon Fridays</p>
          </div>
        </div>
        <div class="group relative overflow-hidden rounded-2xl aspect-square">
          <img src={`${base}images/headshot-4.jpg`} alt="DJ Phase portrait" class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-dark/80 via-transparent to-transparent"></div>
          <div class="absolute bottom-4 left-4">
            <p class="text-xs font-semibold uppercase tracking-wider text-primary-light">The Man</p>
            <p class="text-lg font-bold">Legendary DJ Phase</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Residencies Section -->
  <section class="border-t border-dark-border bg-dark-card">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-light">Every Week</p>
          <h2 class="mt-2 text-3xl font-black sm:text-4xl">Residencies</h2>
        </div>
        <a href={`${base}gigs`} class="text-sm font-medium text-primary-light hover:text-white transition-colors">All gigs →</a>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <!-- Fuego Fridays -->
        <div class="group rounded-xl border border-dark-border bg-dark p-8 hover:border-primary/30 transition-all">
          <div class="flex items-center gap-3 mb-4">
            <span class="rounded-full bg-primary/10 px-4 py-1 text-xs font-bold uppercase tracking-wider text-primary-light">Every Friday</span>
            <span class="text-xs text-light/30">FREE Entry</span>
          </div>
          <h3 class="text-2xl font-black group-hover:text-primary-light transition-colors">FUEGO Fridays</h3>
          <p class="mt-1 text-sm text-light/50">📍 Fuego Bar & Lounge · Seattle</p>
          <p class="mt-3 text-sm text-light/40">House · R&B · Top 40 · Remixes</p>
          <p class="mt-3 text-light/60 text-sm">The best way to kick off your weekend. No cover, good vibes, legendary sets.</p>
        </div>

        <!-- Legion Weekends -->
        <div class="group rounded-xl border border-dark-border bg-dark p-8 hover:border-primary/30 transition-all">
          <div class="flex items-center gap-3 mb-4">
            <span class="rounded-full bg-accent/10 px-4 py-1 text-xs font-bold uppercase tracking-wider text-accent">Fri & Sat</span>
            <span class="text-xs text-light/30">No Cover · Doors 9PM</span>
          </div>
          <h3 class="text-2xl font-black group-hover:text-primary-light transition-colors">Legion Sports Bar</h3>
          <p class="mt-1 text-sm text-light/50">📍 700 Bellevue Way NE, Ste 50 · Bellevue</p>
          <p class="mt-3 text-sm text-light/40">Free Parking Available</p>
          <p class="mt-3 text-light/60 text-sm">The eastside's hottest spot. Great drinks, better music, zero cover charge.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="border-t border-dark-border">
    <div class="mx-auto max-w-4xl px-6 py-24 text-center">
      <h2 class="text-3xl font-black sm:text-4xl">Ready to <span class="gradient-text">Level Up</span> Your Event?</h2>
      <p class="mx-auto mt-4 max-w-xl text-light/50">From Seahawks games to intimate gatherings, DJ Phase brings the energy your event needs.</p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={`${base}contact`} class="inline-flex items-center rounded-full bg-primary px-8 py-3 text-sm font-semibold text-white hover:bg-primary-light transition-all glow-purple">
          Book DJ Phase
        </a>
        <a href="https://www.barbargerz.com" target="_blank" rel="noopener" class="inline-flex items-center rounded-full border border-light/20 px-8 py-3 text-sm font-semibold text-light hover:border-light/40 transition-all">
          Check Out Bar Bangerz →
        </a>
      </div>
    </div>
  </section>
</Layout>
