---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="relative flex min-h-[90vh] items-center justify-center overflow-hidden">
    <!-- Background gradient effect -->
    <div class="absolute inset-0 bg-gradient-to-b from-primary/10 via-dark to-dark"></div>
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 h-[500px] w-[500px] rounded-full bg-primary/20 blur-[120px]"></div>
    <div class="absolute top-1/3 left-1/3 h-[300px] w-[300px] rounded-full bg-accent/10 blur-[100px]"></div>

    <div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.3em] text-primary-light">iHeartRadio • Seattle</p>
      <h1 class="text-6xl font-black leading-tight tracking-tight sm:text-7xl md:text-8xl">
        <span class="gradient-text">DJ PHASE</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-light/60 sm:text-xl">
        Bringing the energy to Seattle's biggest stages. Radio personality by day, party starter by night.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/contact" class="inline-flex items-center rounded-full bg-primary px-8 py-3 text-sm font-semibold text-white hover:bg-primary-light transition-all glow-purple">
          Book DJ Phase
        </a>
        <a href="/gigs" class="inline-flex items-center rounded-full border border-light/20 px-8 py-3 text-sm font-semibold text-light hover:border-light/40 transition-all">
          Upcoming Gigs →
        </a>
      </div>
    </div>
  </section>

  <!-- Quick About Section -->
  <section class="border-t border-dark-border bg-dark-card">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <div class="grid gap-12 md:grid-cols-3">
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-primary/10">
            <span class="text-2xl">🎙️</span>
          </div>
          <h3 class="text-lg font-bold">iHeartRadio</h3>
          <p class="mt-2 text-sm text-light/50">On-air personality bringing the best music to the Pacific Northwest.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-primary/10">
            <span class="text-2xl">🎧</span>
          </div>
          <h3 class="text-lg font-bold">Live Events</h3>
          <p class="mt-2 text-sm text-light/50">Weekend warrior spinning at Seattle's hottest venues and private events.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-primary/10">
            <span class="text-2xl">🎵</span>
          </div>
          <h3 class="text-lg font-bold">Music Curator</h3>
          <p class="mt-2 text-sm text-light/50">Curating vibes that move people — from hip-hop to house and everything in between.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Upcoming Gigs Preview -->
  <section class="border-t border-dark-border">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-light">Next Up</p>
          <h2 class="mt-2 text-3xl font-black sm:text-4xl">Upcoming Gigs</h2>
        </div>
        <a href="/gigs" class="text-sm font-medium text-primary-light hover:text-white transition-colors">View all →</a>
      </div>

      <div class="space-y-4">
        <!-- Gig 1 -->
        <div class="group flex flex-col sm:flex-row items-start sm:items-center gap-4 rounded-xl border border-dark-border bg-dark-card p-6 hover:border-primary/30 transition-all">
          <div class="flex-shrink-0 text-center sm:text-left">
            <p class="text-2xl font-black text-primary-light">MAR 15</p>
            <p class="text-xs text-light/40">Saturday</p>
          </div>
          <div class="flex-grow">
            <h3 class="text-lg font-bold group-hover:text-primary-light transition-colors">Neon Nights at The Showbox</h3>
            <p class="text-sm text-light/50">The Showbox · Seattle, WA · 10PM - 2AM</p>
          </div>
          <span class="rounded-full bg-primary/10 px-4 py-1 text-xs font-semibold text-primary-light">Tickets Available</span>
        </div>

        <!-- Gig 2 -->
        <div class="group flex flex-col sm:flex-row items-start sm:items-center gap-4 rounded-xl border border-dark-border bg-dark-card p-6 hover:border-primary/30 transition-all">
          <div class="flex-shrink-0 text-center sm:text-left">
            <p class="text-2xl font-black text-primary-light">MAR 22</p>
            <p class="text-xs text-light/40">Saturday</p>
          </div>
          <div class="flex-grow">
            <h3 class="text-lg font-bold group-hover:text-primary-light transition-colors">Private Corporate Event</h3>
            <p class="text-sm text-light/50">Downtown Seattle · 7PM - 11PM</p>
          </div>
          <span class="rounded-full bg-light/5 px-4 py-1 text-xs font-semibold text-light/40">Private Event</span>
        </div>

        <!-- Gig 3 -->
        <div class="group flex flex-col sm:flex-row items-start sm:items-center gap-4 rounded-xl border border-dark-border bg-dark-card p-6 hover:border-primary/30 transition-all">
          <div class="flex-shrink-0 text-center sm:text-left">
            <p class="text-2xl font-black text-primary-light">APR 05</p>
            <p class="text-xs text-light/40">Saturday</p>
          </div>
          <div class="flex-grow">
            <h3 class="text-lg font-bold group-hover:text-primary-light transition-colors">Spring Bash at Neumos</h3>
            <p class="text-sm text-light/50">Neumos · Seattle, WA · 9PM - 2AM</p>
          </div>
          <span class="rounded-full bg-primary/10 px-4 py-1 text-xs font-semibold text-primary-light">Tickets Available</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="border-t border-dark-border bg-dark-card">
    <div class="mx-auto max-w-4xl px-6 py-24 text-center">
      <h2 class="text-3xl font-black sm:text-4xl">Ready to <span class="gradient-text">Level Up</span> Your Event?</h2>
      <p class="mx-auto mt-4 max-w-xl text-light/50">From intimate gatherings to massive venues, DJ Phase brings the energy your event needs.</p>
      <a href="/contact" class="mt-8 inline-flex items-center rounded-full bg-primary px-8 py-3 text-sm font-semibold text-white hover:bg-primary-light transition-all glow-purple">
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
