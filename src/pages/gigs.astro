---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Gigs">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-dark to-dark"></div>
    <div class="relative mx-auto max-w-6xl px-6 py-24">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-light">Live Shows</p>
      <h1 class="mt-2 text-4xl font-black sm:text-5xl">Where to Find <span class="gradient-text">DJ Phase</span></h1>
      <p class="mt-4 text-lg text-light/50">Catch me live at these venues and events.</p>
    </div>
  </section>

  <!-- Weekly Residencies -->
  <section class="border-t border-dark-border">
    <div class="mx-auto max-w-4xl px-6 py-16">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent mb-4">Every Week</p>
      <h2 class="text-2xl font-black mb-8">Weekly Residencies</h2>
      
      <div class="space-y-4">
        <!-- Fuego Fridays -->
        <div class="group flex flex-col sm:flex-row items-start sm:items-center gap-6 rounded-xl border border-dark-border bg-dark-card p-6 hover:border-primary/30 transition-all">
          <div class="flex-shrink-0 w-20 text-center">
            <p class="text-2xl font-black text-primary-light">FRI</p>
            <p class="text-xs text-light/40">Every Week</p>
          </div>
          <div class="flex-grow">
            <h3 class="text-xl font-bold group-hover:text-primary-light transition-colors">FUEGO Fridays</h3>
            <p class="mt-1 text-sm text-light/50">📍 Fuego Bar & Lounge · Seattle, WA</p>
            <p class="mt-2 text-sm text-light/60">House · R&B · Top 40 · Remixes — The best way to start your weekend.</p>
          </div>
          <span class="rounded-full bg-green-500/10 px-4 py-1 text-xs font-semibold text-green-400">FREE Entry</span>
        </div>

        <!-- Legion Weekends -->
        <div class="group flex flex-col sm:flex-row items-start sm:items-center gap-6 rounded-xl border border-dark-border bg-dark-card p-6 hover:border-primary/30 transition-all">
          <div class="flex-shrink-0 w-20 text-center">
            <p class="text-2xl font-black text-accent">FRI</p>
            <p class="text-2xl font-black text-accent">&</p>
            <p class="text-2xl font-black text-accent">SAT</p>
          </div>
          <div class="flex-grow">
            <h3 class="text-xl font-bold group-hover:text-primary-light transition-colors">Legion Sports Bar</h3>
            <p class="mt-1 text-sm text-light/50">📍 700 Bellevue Way NE, Ste 50 · Bellevue, WA</p>
            <p class="mt-1 text-sm text-light/40">🕘 Doors 9PM · Free Parking</p>
            <p class="mt-2 text-sm text-light/60">The eastside's go-to spot for great music and good times.</p>
          </div>
          <span class="rounded-full bg-green-500/10 px-4 py-1 text-xs font-semibold text-green-400">No Cover</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Past / Notable Events -->
  <section class="border-t border-dark-border bg-dark-card">
    <div class="mx-auto max-w-4xl px-6 py-16">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-light mb-4">Highlights</p>
      <h2 class="text-2xl font-black mb-8">Notable Events</h2>

      <div class="space-y-4">
        <div class="group flex flex-col sm:flex-row items-start sm:items-center gap-6 rounded-xl border border-dark-border bg-dark p-6 hover:border-primary/30 transition-all">
          <div class="flex-shrink-0 w-20 text-center">
            <p class="text-lg font-black text-primary-light">🏈</p>
          </div>
          <div class="flex-grow">
            <h3 class="text-xl font-bold group-hover:text-primary-light transition-colors">Seattle Seahawks Game Day DJ</h3>
            <p class="mt-1 text-sm text-light/50">📍 Lumen Field · 300 Level Concourse · Seattle, WA</p>
            <p class="mt-2 text-sm text-light/60">Bringing the energy to the 12s on game days.</p>
          </div>
          <span class="rounded-full bg-primary/10 px-4 py-1 text-xs font-semibold text-primary-light">Game Days</span>
        </div>

        <div class="group flex flex-col sm:flex-row items-start sm:items-center gap-6 rounded-xl border border-dark-border bg-dark p-6 hover:border-primary/30 transition-all">
          <div class="flex-shrink-0 w-20 text-center">
            <p class="text-lg font-black text-primary-light">🎆</p>
          </div>
          <div class="flex-grow">
            <h3 class="text-xl font-bold group-hover:text-primary-light transition-colors">NYE Countdown</h3>
            <p class="mt-1 text-sm text-light/50">📍 Multiple Venues · Seattle & Bellevue</p>
            <p class="mt-2 text-sm text-light/60">The go-to DJ for ringing in the New Year. Every year.</p>
          </div>
          <span class="rounded-full bg-accent/10 px-4 py-1 text-xs font-semibold text-accent">Annual</span>
        </div>

        <div class="group flex flex-col sm:flex-row items-start sm:items-center gap-6 rounded-xl border border-dark-border bg-dark p-6 hover:border-primary/30 transition-all">
          <div class="flex-shrink-0 w-20 text-center">
            <p class="text-lg font-black text-primary-light">🏎️</p>
          </div>
          <div class="flex-grow">
            <h3 class="text-xl font-bold group-hover:text-primary-light transition-colors">Private Events & Corporate</h3>
            <p class="mt-1 text-sm text-light/50">📍 LeMay Car Museum, Hotels, Corporate Venues</p>
            <p class="mt-2 text-sm text-light/60">Weddings, galas, brand activations — the full experience.</p>
          </div>
          <span class="rounded-full bg-light/5 px-4 py-1 text-xs font-semibold text-light/40">By Inquiry</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Booking CTA -->
  <section class="border-t border-dark-border">
    <div class="mx-auto max-w-4xl px-6 py-16 text-center">
      <h2 class="text-2xl font-black">Want DJ Phase at Your Event?</h2>
      <p class="mt-2 text-light/50">Weddings, corporate events, private parties, festivals — let's make it happen.</p>
      <a href={`${base}contact`} class="mt-6 inline-flex items-center rounded-full bg-primary px-8 py-3 text-sm font-semibold text-white hover:bg-primary-light transition-all glow-purple">
        Book Now
      </a>
    </div>
  </section>
</Layout>
